{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "ghostty",
      "camelcase": "Ghostty",
      "scope": "source.ghostty",
      "path": ".",
      "file-types": null,
      "injection-regex": "^ghostty$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Parser for Ghostty configuration files",
    "authors": [
      {
        "name": "Bez Hermoso",
        "email": "me@bez.dev"
      }
    ],
    "links": {
      "repository": "https://github.com/bezhermoso/tree-sitter-ghostty"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}